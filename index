    function renderSessions(sessions) {
        const grid = document.getElementById('sessionsGrid');
        const count = document.getElementById('sessionCount');
        count.textContent = sessions.length + ' session' + (sessions.length !== 1 ? 's' : '') + ' shown';

        if (sessions.length === 0) {
            grid.innerHTML = '<div class="no-results">No sessions match your filters. Try adjusting your search.</div>';
            return;
        }

        grid.innerHTML = sessions.map(s => {
            const catClass = s.category.toLowerCase();
            return `
            <div class="session-card">
                <div class="session-header">
                    <span class="session-slot">Session ${s.session}: ${SESSION_TIMES[s.session]}</span>
                </div>
                <span class="category-badge ${catClass}">${s.category}</span>
                <h3>${s.title}</h3>
                <div class="presenter">${s.presenter}</div>
                <div class="description">
                    <div class="description-text" id="desc-${s.id}">${s.description}</div>
                    <button class="read-more-btn" onclick="toggleDesc(${s.id})">Read more</button>
                </div>
                <div class="session-info">
                    <span class="info-item">📍 Room ${s.room}</span>
                    ${s.audience ? '<span class="info-item">👥 ' + s.audience + '</span>' : ''}
                </div>
            </div>`;
        }).join('');
    }

    function toggleDesc(id) {
        const el = document.getElementById('desc-' + id);
        const btn = el.parentElement.querySelector('.read-more-btn');
        el.classList.toggle('expanded');
        btn.textContent = el.classList.contains('expanded') ? 'Read less' : 'Read more';
    }

    function filterSessions() {
        const sessionVal = document.getElementById('sessionFilter').value;
        const categoryVal = document.getElementById('categoryFilter').value;
        const searchVal = document.getElementById('searchInput').value.toLowerCase();

        let filtered = SESSIONS;
        if (sessionVal !== 'all') filtered = filtered.filter(s => s.session === sessionVal);
        if (categoryVal !== 'all') filtered = filtered.filter(s => s.category === categoryVal);
        if (searchVal) {
            filtered = filtered.filter(s =>
                s.title.toLowerCase().includes(searchVal) ||
                s.presenter.toLowerCase().includes(searchVal) ||
                s.description.toLowerCase().includes(searchVal) ||
                s.room.toLowerCase().includes(searchVal)
            );
        }
        renderSessions(filtered);
    }

    // Initial render
    renderSessions(SESSIONS);
    </script>
